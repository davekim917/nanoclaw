{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/repo-readiness-guard.cjs",
            "timeout": 10,
            "statusMessage": "Checking repo readiness..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/post-commit-verify.cjs",
            "timeout": 30,
            "statusMessage": "Analyzing blast radius of commit..."
          }
        ]
      }
    ]
  }
}
